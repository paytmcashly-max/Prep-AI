rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Baseline production rules must be tested with the Firebase Emulator Suite before launch.
    // Deny by default. Add narrow, reviewed exceptions only when a feature requires them.
    match /{document=**} {
      allow read, write: if false;
    }

    // User-owned app data. Users may only access their own subtree.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Subscription status is written by the backend/Admin after server-side verification.
      // Clients may read their own status for UI, but must not be able to grant themselves premium.
      match /subscription/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /profile/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /sessions/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /dailyUsage/{docId} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
